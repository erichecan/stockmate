# StockFlow Backend Environment Configuration

# Neon PostgreSQL - 必须用 Pooler 端点（host 含 -pooler），标准 TCP，Cloud Run 兼容
# 格式: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon 直连（用于 migrations）
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT Configuration
JWT_ACCESS_SECRET="your-access-secret"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Application
PORT=3001
NODE_ENV=development

# Neon API (for creating tenant databases)
NEON_API_KEY=""
NEON_PROJECT_ID=""

  operatorId  String                @map("operator_id")
  openedAt    DateTime              @map("opened_at")
  closedAt    DateTime?             @map("closed_at")
  openingCash Decimal?              @map("opening_cash") @db.Decimal(12, 2)
  closingCash Decimal?              @map("closing_cash") @db.Decimal(12, 2)
  status      CashbookSessionStatus @default(OPEN)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions CashbookTransaction[]

  @@index([tenantId])
  @@index([operatorId])
  @@index([openedAt])
  @@map("cashbook_sessions")
}

enum CashbookSessionStatus {
  OPEN
  CLOSED
}

model CashbookTransaction {
  id            String                  @id @default(uuid())
  tenantId      String                  @map("tenant_id")
  sessionId     String                  @map("session_id")
  type          CashbookTransactionType
  amount        Decimal                 @db.Decimal(12, 2)
  description   String?
  referenceType String?                 @map("reference_type")
  referenceId   String?                 @map("reference_id")
  createdAt     DateTime                @default(now()) @map("created_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session CashbookSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("cashbook_transactions")
}

enum CashbookTransactionType {
  IN
  OUT
}
